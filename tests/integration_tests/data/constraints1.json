      "eom"
    ],
    "constraints": [
      "x == Date(2023, 1, 31)",
      "y == x + Period(0, 3, 0)",
      "y == Date(2023, 4, 30)"
    ],
    "date_variables": [
      "x",
      "y"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-7",
    "description": "Tight inequality window that is unsatisfiable",
    "coverage_tags": [
      "ineq_window"
    ],
    "constraints": [
      "x > Date(2022, 2, 28)",
      "x < Date(2022, 3, 1)"
    ],
    "date_variables": [
      "x"
    ],
    "period_variables": []
  },
  {
