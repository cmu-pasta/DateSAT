[
  {
    "id": "1758086606-1",
    "description": "Check if a date is February 29 in a leap year",
    "coverage_tags": [
      "leap_boundary"
    ],
    "constraints": [
      "x >= Date(2000, 2, 28)",
      "x <= Date(2000, 3, 1)",
      "x != Date(2000, 2, 28)",
      "x != Date(2000, 3, 1)"
    ],
    "date_variables": [
      "x"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-2",
    "description": "Adding 1 month vs adding 30 days can produce different results at month boundaries",
    "coverage_tags": [
      "month_vs_days",
      "eom"
    ],
    "constraints": [
      "x >= Date(2023, 1, 1)",
      "x <= Date(2023, 1, 31)",
      "(x + Period(0, 1, 0)) != (x + Period(0, 0, 30))"
    ],
    "date_variables": [
      "x"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-3",
    "description": "Adding 1 year vs 366 days differs when crossing leap year boundaries",
    "coverage_tags": [
      "year_vs_days",
      "leap_boundary"
    ],
    "constraints": [
      "x >= Date(2019, 12, 1)",
      "x <= Date(2020, 2, 29)",
      "(x + Period(1, 0, 0)) != (x + Period(0, 0, 366))"
    ],
    "date_variables": [
      "x"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-4",
    "description": "Chain of period additions that requires normalization",
    "coverage_tags": [
      "chain_add"
    ],
    "constraints": [
      "x == Date(2022, 1, 15)",
      "y == x + Period(0, 13, 40)",
      "y != Date(2023, 2, 24)"
    ],
    "date_variables": [
      "x",
      "y"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-5",
    "description": "Three dates must be exactly 1 month apart within a specific range",
    "coverage_tags": [
      "multi_var",
      "ineq_window"
    ],
    "constraints": [
      "x >= Date(2022, 1, 1)",
      "z <= Date(2022, 5, 31)",
      "y == x + Period(0, 1, 0)",
      "z == y + Period(0, 1, 0)",
      "z - x == Period(0, 2, 0)"
    ],
    "date_variables": [
      "x",
      "y",
      "z"
    ],
    "period_variables": []
  },
  {
    "id": "1758086606-6",
